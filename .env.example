# =============================================================================
# StableAgents — environment template
#
# Copy to .env, fill in, NEVER commit.
# =============================================================================

# --- Network ---------------------------------------------------------------
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# --- Deployer wallet -------------------------------------------------------
# Use a throwaway testnet key for `forge script`. For production deploys,
# prefer `cast wallet import deployer --interactive` (encrypted keystore)
# and the `--account deployer` flag.
PRIVATE_KEY=

# --- Token + identity addresses (Arc Testnet) ------------------------------
USDC_ADDRESS=0x3600000000000000000000000000000000000000
ERC8004_IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
CCTP_MESSAGE_TRANSMITTER=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275

# --- Deployed StableAgents contracts (filled after deploy) -----------------
AGENT_REGISTRY_ADDRESS=
JOB_ESCROW_ADDRESS=
CROSS_CHAIN_GATEWAY_ADDRESS=
X402_MIDDLEWARE_ADDRESS=
ONE_SHOT_ENROLL_ADDRESS=

# --- Optional: ArcScan API key for `forge verify-contract` -----------------
ARCSCAN_KEY=

# --- Optional: minimum stake override (defaults to 10 USDC in script) ------
MIN_STAKE=
